```gitignore
# ==========================================================
# Hotel Python Palace
# .gitignore
# ==========================================================

# -------------------------
# Python
# -------------------------
__pycache__/
*.py[cod]
*$py.class

# Compiled Python files
*.so

# Distribution / packaging
.Python
build/
dist/
downloads/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
wheels/
*.egg-info/
.installed.cfg
*.egg

# -------------------------
# Virtual Environments
# -------------------------
venv/
env/
ENV/
.venv/

# -------------------------
# Flask
# -------------------------
instance/
.webassets-cache/

# -------------------------
# Environment Variables
# -------------------------
.env
.env.*
!.env.example

# -------------------------
# SQLite Databases
# -------------------------
*.db
*.sqlite
*.sqlite3

# Keep example databases if needed
!example.db

# -------------------------
# Logs
# -------------------------
*.log
logs/
log/

# -------------------------
# Cache
# -------------------------
.cache/
.pytest_cache/
.mypy_cache/
.pyre/
.coverage
coverage.xml
htmlcov/

# -------------------------
# Jupyter
# -------------------------
.ipynb_checkpoints/

# -------------------------
# VS Code
# -------------------------
.vscode/

# -------------------------
# JetBrains
# -------------------------
.idea/

# -------------------------
# macOS
# -------------------------
.DS_Store

# -------------------------
# Windows
# -------------------------
Thumbs.db
Desktop.ini

# -------------------------
# Temporary Files
# -------------------------
*.tmp
*.temp
*.bak
*.swp

# -------------------------
# Uploaded Files
# -------------------------
uploads/
temp/

# -------------------------
# Generated Reports
# -------------------------
reports/
exports/

# -------------------------
# Secrets
# -------------------------
secrets.json
credentials.json
```
